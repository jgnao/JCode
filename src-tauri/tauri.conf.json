{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jcode",
  "version": "0.1.0",
  "identifier": "jgcode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "devtools": true,
        "title": "JCode",
        "width": 1280,
        "height": 720,
        "maximized": false,
        "label": "main",
        "decorations": false
      }
   ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
